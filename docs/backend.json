
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents basic user information, optimized for search and filtering queries.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "description": "The user's primary email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The user's role (e.g., 'Player', 'Coach', 'Club')."
        },
        "discipline": {
          "type": "string",
          "description": "The sport discipline (e.g., 'Football', 'Futsal')."
        },
        "status": {
          "type": "string",
          "description": "Current availability status."
        },
        "score": {
          "type": "number",
          "description": "Relevance score for rankings."
        },
        "views": {
          "type": "number",
          "description": "Total profile views."
        },
        "province": {
          "type": "string",
          "description": "The geographic province from the official resources list."
        },
        "country": {
          "type": "string",
          "description": "Current country of residence."
        },
        "nationality": {
          "type": "string",
          "description": "User's nationality."
        },
        "level": {
          "type": "string",
          "description": "Professional or skill level."
        },
        "verificationStatus": {
          "type": "string",
          "description": "Certification verification status."
        },
        "plan": {
          "type": "string",
          "enum": ["free", "verified", "pro", "top"],
          "description": "The subscription plan of the user."
        },
        "age": {
          "type": "number"
        },
        "position": {
          "type": "string"
        },
        "profileImageUrl": {
          "type": "string"
        },
        "instagram": { "type": "string" },
        "tiktok": { "type": "string" },
        "twitter": { "type": "string" }
      },
      "required": [
        "id",
        "email",
        "role",
        "discipline",
        "status",
        "score",
        "verificationStatus"
      ]
    },
    "Offer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Offer",
      "type": "object",
      "description": "A recruitment offer or public job vacancy from a Club.",
      "properties": {
        "id": { "type": "string" },
        "clubId": { "type": "string" },
        "clubName": { "type": "string" },
        "clubLogo": { "type": "string" },
        "position": { "type": "string" },
        "salaryRange": { "type": "string" },
        "bonusObjectives": { "type": "string" },
        "duration": { "type": "string" },
        "onboardingDate": { "type": "string" },
        "teamRole": { "type": "string" },
        "teamCategory": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "pending", "accepted", "rejected", "withdrawn"] },
        "description": { "type": "string" },
        "requirements": { "type": "string" },
        "accommodation": { "type": "string" },
        "transport": { "type": "string" },
        "healthInsurance": { "type": "string" },
        "careerPlan": { "type": "string" },
        "nationalityRequirement": { "type": "string" },
        "preferredAgeRange": { "type": "string" },
        "languageLevel": { "type": "string" },
        "mandatoryDocs": { "type": "string" },
        "role": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clubId", "status", "position"]
    },
    "Match": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Match",
      "type": "object",
      "description": "Represents a connection between two users.",
      "properties": {
        "id": { "type": "string" },
        "members": { 
          "type": "object",
          "description": "Map of user IDs involved in the match."
        },
        "status": { 
          "type": "string", 
          "enum": ["pending", "accepted", "rejected"] 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "members", "status"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Detailed biographical and media content.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bio": { "type": "string" },
        "isAiBio": { "type": "boolean" },
        "teamHistory": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "season": { "type": "string" },
              "club": { "type": "string" },
              "league": { "type": "string" },
              "leaguePosition": { "type": "string" },
              "promotion": { "type": "string" },
              "wins": { "type": "number" },
              "draws": { "type": "number" },
              "losses": { "type": "number" },
              "goals": { "type": "number" },
              "assists": { "type": "number" },
              "matches": { "type": "number" },
              "position": { "type": "string" }
            }
          } 
        },
        "videoUrls": { "type": "array", "items": { "type": "string" } },
        "socialVideoUrls": { "type": "array", "items": { "type": "string" } },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "strongFoot": { "type": "string" },
        "bookImageUrls": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "analysis": { "type": "string" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "stadium": { "type": "string" },
        "foundationYear": { "type": "string" },
        "facilities": { "type": "string" },
        "tacticalSystem": { "type": "string" },
        "philosophy": { "type": "array", "items": { "type": "string" } },
        "averageAge": { "type": "number" },
        "academyUsage": { "type": "number" },
        "salaryRange": { "type": "string" },
        "contractPrefs": { "type": "array", "items": { "type": "string" } },
        "foreignerSpots": { "type": "string" },
        "preferredMarkets": { "type": "array", "items": { "type": "string" } },
        "scoutingResponsible": { "type": "string" },
        "contactChannel": { "type": "string" },
        "urgencyLevel": { "type": "string" },
        "requiredLanguages": { "type": "array", "items": { "type": "string" } },
        "psychologicalProfile": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "bio"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Publicly searchable user identities."
        }
      },
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Rich public profile content."
        }
      },
      {
        "path": "/offers/{offerId}",
        "definition": {
          "entityName": "Offer",
          "schema": { "$ref": "#/backend/entities/Offer" },
          "description": "Public job vacancies or direct recruitment offers."
        }
      },
      {
        "path": "/matches/{matchId}",
        "definition": {
          "entityName": "Match",
          "schema": { "$ref": "#/backend/entities/Match" },
          "description": "Connections between users."
        }
      }
    ]
  }
}
