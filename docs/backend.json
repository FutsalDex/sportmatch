
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents basic user information, optimized for search and filtering queries.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "description": "The user's primary email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The user's role (e.g., 'Player', 'Coach', 'Club')."
        },
        "discipline": {
          "type": "string",
          "description": "The sport discipline (e.g., 'Football', 'Futsal')."
        },
        "status": {
          "type": "string",
          "description": "Current availability status."
        },
        "score": {
          "type": "number",
          "description": "Relevance score for rankings."
        },
        "province": {
          "type": "string",
          "description": "The geographic province from the official resources list."
        },
        "country": {
          "type": "string",
          "description": "Current country of residence."
        },
        "nationality": {
          "type": "string",
          "description": "User's nationality."
        },
        "level": {
          "type": "string",
          "description": "Professional or skill level."
        },
        "verificationStatus": {
          "type": "string",
          "description": "Certification verification status."
        },
        "age": {
          "type": "number"
        },
        "position": {
          "type": "string"
        },
        "profileImageUrl": {
          "type": "string"
        },
        "instagram": { "type": "string" },
        "tiktok": { "type": "string" },
        "twitter": { "type": "string" }
      },
      "required": [
        "id",
        "email",
        "role",
        "discipline",
        "status",
        "score",
        "verificationStatus"
      ]
    },
    "Province": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Province",
      "type": "object",
      "description": "Official province entry for location normalization.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Detailed biographical and media content.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bio": { "type": "string" },
        "teamHistory": { "type": "array", "items": { "type": "object" } },
        "videoUrls": { "type": "array", "items": { "type": "string" } },
        "socialVideoUrls": { "type": "array", "items": { "type": "string" } },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "strongFoot": { "type": "string" },
        "bookImageUrls": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "analysis": { "type": "string" }
      },
      "required": ["id", "userId", "bio"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Publicly searchable user identities."
        }
      },
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Rich public profile content."
        }
      }
    ]
  }
}
