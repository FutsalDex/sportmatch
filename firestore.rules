
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == "admin01@gmail.com"; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isMemberInMap(map) { return isSignedIn() && map != null && map[request.auth.uid] == true; }

    // --- COLLECTION RULES ---

    // Recursos públicos (Provincias, etc)
    match /recursos/{document=**} {
      allow read: if true; 
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /offers/{offerId} {
      // Permitir lectura a cualquier usuario registrado para el Tablero de Ofertas
      allow read: if isSignedIn();
      // Permitir creación si está identificado
      allow create: if isSignedIn();
      // Solo el club emisor o el admin pueden editar/borrar
      allow update, delete: if isAdmin() || (isSignedIn() && resource != null && isOwner(resource.data.clubId));
    }

    match /privateProfiles/{userId} {
      allow get: if isAdmin() || isOwner(userId) || (resource != null && isMemberInMap(resource.data.allowedReaders));
      allow list: if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
    }

    match /matches/{matchId} {
      allow read, write: if isAdmin() || (isSignedIn() && (resource == null || isMemberInMap(resource.data.members)));
    }
    
    // Regla global para el admin en cualquier otro documento futuro
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
