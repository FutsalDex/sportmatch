
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isMemberInMap(map) { return isSignedIn() && map != null && map[request.auth.uid] == true; }

    // --- COLLECTION RULES ---

    // Recursos públicos (Provincias, etc)
    match /recursos/{document=**} {
      allow read: if true; // Lectura pública para validación en formularios
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /privateProfiles/{userId} {
      allow get: if isOwner(userId) || isMemberInMap(resource.data.allowedReaders);
      allow list: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /matches/{matchId} {
      allow read, write: if isSignedIn() && (resource == null || isMemberInMap(resource.data.members));
    }
  }
}
